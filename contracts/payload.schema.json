{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jurimetria/contracts/payload.schema.json",
  "title": "PayloadTaxaCongestionamentoMensal",
  "description": "Contrato do payload produzido pelo pipeline de taxa de congestionamento e consumido pelo pipeline de EDA/previsão/dashboard.",
  "type": "object",
  "required": ["schema_version", "metadata", "data"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": [
        "gerado_em", "metrica", "janela_baixados_meses", "grao",
        "competencia_min", "competencia_max", "record_count", "checksum_sha256"
      ],
      "additionalProperties": true,
      "properties": {
        "gerado_em": {"type": "string", "format": "date-time"},
        "metrica": {"type": "string"},
        "janela_baixados_meses": {"type": "integer", "minimum": 1},
        "grao": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "competencia_min": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
        "competencia_max": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
        "record_count": {"type": "integer", "minimum": 0},
        "checksum_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "competencia", "comarca", "serventia",
          "processos_distribuidos", "processos_baixados",
          "estoque_pendente", "baixados_ultimos_12_meses",
          "taxa_congestionamento_pct"
        ],
        "additionalProperties": true,
        "properties": {
          "competencia": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
          "comarca": {"type": "string"},
          "serventia": {"type": "string"},
          "processos_distribuidos": {"type": "integer", "minimum": 0},
          "processos_baixados": {"type": "integer", "minimum": 0},
          "estoque_pendente": {"type": "integer", "minimum": 0},
          "baixados_ultimos_12_meses": {"type": "integer", "minimum": 0},
          "taxa_congestionamento_pct": {"type": "number", "minimum": 0, "maximum": 100}
        }
      }
    }
  }
}